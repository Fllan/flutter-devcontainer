{
  "name": "Flutter & Dart",
  "build": {
    "dockerfile": "../Dockerfile",
    "args": {
      "INSTALL_KIRO": "false",
      "INSTALL_SERVERPOD": "false",
      "INSTALL_NODEJS": "false"
    }
  },
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "remoteUser": "vscode",
  "postCreateCommand": "mkdir -p /home/vscode/.cache/Google/AndroidStudio2024.3 && printf '/opt/android-studio' > /home/vscode/.cache/Google/AndroidStudio2024.3/.home && flutter doctor -v",
  "customizations": {
    "vscode": {
      "extensions": ["Dart-Code.dart-code", "Dart-Code.flutter"],
      "settings": {
        "dart.flutterSdkPath": "/home/vscode/flutter"
      }
    }
  }
}
